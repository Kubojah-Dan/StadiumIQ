# ═══════════════════════════════════════════════════════════
# StadiumIQ — Environment Variables
# Copy to .env and fill in real values before running locally
# ═══════════════════════════════════════════════════════════

# ── GCP Configuration ───────────────────────────────────────
GCP_PROJECT_ID=promptwars-493015
GCP_REGION=asia-south1

# ── Web / Realtime URLs ──────────────────────────────────────
# Local development:
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_REALTIME_WS_URL=ws://localhost:8001
# Cloud Run (replace with actual *.run.app URLs after first deploy):
# NEXT_PUBLIC_API_URL=https://stadiumiq-core-api-<hash>-el.a.run.app
# NEXT_PUBLIC_REALTIME_WS_URL=wss://stadiumiq-realtime-<hash>-el.a.run.app

# ── Database ─────────────────────────────────────────────────
# Local Docker:
DATABASE_URL=postgresql+asyncpg://stadiumiq:password@localhost:5432/stadiumiq_dev
# Cloud SQL (production — set via Cloud Run env vars, not here):
# DATABASE_URL=postgresql+asyncpg://stadiumiq:<pass>@<cloud-sql-private-ip>/stadiumiq_production

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
# Memorystore (production — set via Cloud Run env vars):
# REDIS_URL=redis://<memorystore-host>:6379

# ── Auth ─────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production-use-long-random-string

# ── Google Services ──────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_MAPS_EMBED_API_KEY=
GOOGLE_GEMINI_API_KEY=
GOOGLE_GEMINI_MODEL=gemini-2.0-flash

# ── Optional: Live Stadium Feeds ─────────────────────────────
# Format: STADIUMIQ_FEED_<STADIUM_ID_UPPERCASE>
STADIUMIQ_FEED_IN_NARENDRA_MODI=
STADIUMIQ_FEED_IN_EDEN_GARDENS=
STADIUMIQ_FEED_IN_WANKHEDE=
